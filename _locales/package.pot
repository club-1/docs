msgid "Informations de connexion"
msgstr ""

#: ../../outils/ldap.md:50
msgid ""
"L'annuaire LDAP de CLUB1 n'est pas public, il est accessible uniquement en "
"local depuis le serveur."
msgstr ""

#: ../../outils/ldap.md:31 ../../services/email.md:133 ../../services/ftp.md:4
#: ../../services/sql.md:50 ../../services/ssh.md:34
#: ../../services/webcast.md:5
